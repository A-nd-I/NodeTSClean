{
   "name": "boilerplate-nodets-cleanarch",
   "version": "1.0.0",
   "description": "",
   "main": "index.js",
   "type": "module",
   "scripts": {
      "dev": "tsx --watch src/app.ts",
      "build": "rimraf ./dist && tsc",
      "start": "node dist/app.js",
      "check:updates": "pnpm outdated",
      "audit": "pnpm audit",
      "type-check": "tsc --noEmit",
      "build:prod": "tsc -p tsconfig.build.json",
      "lint:check": "eslint .",
      "lint:fix": "eslint --fix .",
      "format": "prettier --write .",
      "format:check": "prettier --check .",
      "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watchAll",
      "test:run": "NODE_OPTIONS='--experimental-vm-modules' jest",
      "coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
      "prepare": "husky"
   },
   "keywords": [],
   "author": "",
   "license": "MIT",
   "imports": {
      "#*": "./src/*"
   },
   "lint-staged": {
      "*.{js,ts}": [
         "prettier --write",
         "eslint --fix",
         "sh -c '! grep -Ei \"api_key|secret|password|token|auth_\" \"$@\"'"
      ],
      "*.{json,yml,yaml}": [
         "prettier --write"
      ],
      "*.{md,css,scss}": [
         "prettier --write"
      ]
   },
   "devDependencies": {
      "@eslint/js": "^10.0.1",
      "@jest/globals": "30.3.0",
      "@tsconfig/node22": "^22.0.5",
      "@types/bcryptjs": "^3.0.0",
      "@types/express": "^4.17.25",
      "@types/jest": "^30.0.0",
      "@types/node": "^25.5.2",
      "@types/pg": "^8.20.0",
      "eslint": "^10.2.0",
      "eslint-plugin-jest": "^29.15.2",
      "eslint-plugin-perfectionist": "^5.8.0",
      "husky": "^9.1.7",
      "jest": "^30.3.0",
      "lint-staged": "^16.4.0",
      "prettier": "^3.8.1",
      "prisma": "^7.8.0",
      "rimraf": "^6.1.3",
      "ts-jest": "^29.4.6",
      "ts-node-dev": "^2.0.0",
      "tsx": "^4.21.0",
      "typescript": "^6.0.2",
      "typescript-eslint": "^8.58.0"
   },
   "dependencies": {
      "@prisma/adapter-pg": "^7.8.0",
      "@prisma/client": "^7.8.0",
      "bcryptjs": "^3.0.3",
      "dotenv": "^17.4.0",
      "env-var": "^7.4.1",
      "express": "^4.22.1",
      "pg": "^8.20.0"
   },
   "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
